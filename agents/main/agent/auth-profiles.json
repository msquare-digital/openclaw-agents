{
  "version": 1,
  "profiles": {
    "openai:default": {
      "type": "api_key",
      "provider": "openai",
      "key": "${OPENAI_API_KEY}"
    },
    "openrouter:default": {
      "type": "api_key",
      "provider": "openrouter",
      "key": "${OPENROUTER_API_KEY}"
    },
    "openai-codex:YOUR_EMAIL": {
      "type": "oauth",
      "provider": "openai-codex",
      "email": "YOUR_EMAIL"
    }
  }
}
