# Copy to live.env (do not commit) and set real values.
# Example:
# cp workspaces/growbox/config/live.env.example workspaces/growbox/config/live.env

# ACInfinity
export ACINFINITY_API_BASE="http://www.acinfinityserver.com"
# Auth option A (recommended): email/password
export ACINFINITY_EMAIL=""
export ACINFINITY_EMAIL_FILE="$HOME/.openclaw/secrets/acinfinity-email"
export ACINFINITY_PASSWORD=""
export ACINFINITY_PASSWORD_FILE="$HOME/.openclaw/secrets/acinfinity-password"
# Auth option B: token
export ACINFINITY_TOKEN=""
export ACINFINITY_TOKEN_FILE="$HOME/.openclaw/secrets/acinfinity-token"
# Optional: target specific controller
# export ACINFINITY_DEVICE_ID="<acinfinity-device-id>"

# Ecowitt
export ECOWITT_API_BASE="https://api.ecowitt.net/api/v3"
# Use exactly one source for each key:
export ECOWITT_APPLICATION_KEY=""
export ECOWITT_APPLICATION_KEY_FILE="$HOME/.openclaw/secrets/ecowitt-application-key"
export ECOWITT_API_KEY=""
export ECOWITT_API_KEY_FILE="$HOME/.openclaw/secrets/ecowitt-api-key"
export ECOWITT_MAC=""
export ECOWITT_MAC_FILE="$HOME/.openclaw/secrets/ecowitt-mac"
# Optional:
# export ECOWITT_SOIL_CHANNEL="1"
# export ECOWITT_PLUG_DEVICE_KEY="AC1100-00002A12"

# Optional timeout for both connectors
export GROWBOX_CONNECTOR_TIMEOUT="12"
