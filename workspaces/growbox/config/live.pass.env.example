# Local secret manager with pass (recommended for Raspberry-only setup)
# Copy to ~/.openclaw/secrets/growbox.pass.env and edit non-secret fields.
# Secrets stay in pass entries, not in this file.

ACINFINITY_API_BASE="http://www.acinfinityserver.com"
# Auth option A (recommended): email/password
ACINFINITY_EMAIL_PASS_ENTRY="growbox/acinfinity/email"
ACINFINITY_PASSWORD_PASS_ENTRY="growbox/acinfinity/password"
# Auth option B: already known token
# ACINFINITY_TOKEN_PASS_ENTRY="growbox/acinfinity/token"
# Optional: if you want a specific controller
# ACINFINITY_DEVICE_ID="<acinfinity-device-id>"

ECOWITT_API_BASE="https://api.ecowitt.net/api/v3"
ECOWITT_APPLICATION_KEY_PASS_ENTRY="growbox/ecowitt/application_key"
ECOWITT_API_KEY_PASS_ENTRY="growbox/ecowitt/api_key"
ECOWITT_MAC_PASS_ENTRY="growbox/ecowitt/mac"
# Optional:
# ECOWITT_SOIL_CHANNEL="1"
# ECOWITT_PLUG_DEVICE_KEY="AC1100-00002A12"

GROWBOX_CONNECTOR_TIMEOUT="12"

# Monitoring cycle + channel notify
# Beispiel: Command muss Nachricht von stdin lesen.
# GROWBOX_NOTIFY_COMMAND="openclaw channel send --channel growbox-alerts --stdin"
# Optional alternative Dateien:
# GROWBOX_PLANT_PROFILE_FILE="$HOME/.openclaw/workspace/growbox/config/plant-profile.yaml"
# GROWBOX_THRESHOLDS_FILE="$HOME/.openclaw/workspace/growbox/config/thresholds.yaml"
